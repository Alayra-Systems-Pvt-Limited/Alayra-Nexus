{
  "name": "alayra-nexus-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end proof for Alayra Nexus: black-box tests against the compiled server, a real PostgreSQL, a real Redis, and a real browser.",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:browser": "playwright test --project=browser",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.0",
    "eslint": "^9.20.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.24.0"
  }
}
